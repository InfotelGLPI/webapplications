{
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "autoloader-suffix": "GlpiPluginWebapplications",
        "platform": {
            "php": "8.2.99"
        },
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "require-dev": {
        "glpi-project/tools": "^0.8",
        "friendsofphp/php-cs-fixer": "^3.94",
        "php-parallel-lint/php-parallel-lint": "^1.4",
        "glpi-project/phpstan-glpi": "^1.1",
        "phpunit/phpunit": "^11.5"
    },
    "require": {
        "setasign/fpdf": "^1.9",
        "php": ">=8.2"
    },
    "scripts": {
        "lint": "parallel-lint --exclude vendor --exclude node_modules .",
        "cs": "php-cs-fixer fix --dry-run --diff --ansi",
        "cs-fix": "php-cs-fixer fix --ansi",
        "phpstan": "phpstan analyze --ansi --memory-limit=1G",
        "qa": [
            "@lint",
            "@phpstan",
            "@cs"
        ]
    }
}
