{% import 'components/form/fields_macros.html.twig' as fields %}
{% set params  = params ?? [] %}
{% set field_options = {
    'full_width': true,
    'add_field_class': (is_expanded ? 'col-sm-12' : ''),
} %}

{% block more_fields %}

    {% set editor_item = get_item(params['itemtype'], params['items_id']) %}
    {{ fields.htmlField(
        'editor',
        editor_item.getLink(),
        __("Referent editor", 'webapplications'),
        field_options|merge({
            'add_field_class': 'col-sm-12',
        })
    ) }}

    {{ fields.htmlField(
        "email",
        params['editoremail'],
        __("Mail support", 'webapplications'),
        field_options|merge({
            'add_field_class': 'col-sm-12',
        })
    ) }}

    {{ fields.htmlField(
        "phonenumber",
        params['editorephonenumber'],
        __("Phone support", 'webapplications'),
        field_options|merge({
            'add_field_class': 'col-sm-12',
        })
    ) }}

{% endblock %}
